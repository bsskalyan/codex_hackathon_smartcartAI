LIVE_BLINKIT_SEARCH_URL=https://your-blinkit-endpoint.example/search?query={query}&pincode={pincode}
LIVE_INSTAMART_SEARCH_URL=https://your-instamart-endpoint.example/search?query={query}&pincode={pincode}
